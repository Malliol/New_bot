# ── Telegram ──────────────────────────────────────────────────────────────────
# Получить на https://my.telegram.org/apps
TG_API_ID=123456
TG_API_HASH=abcdef1234567890abcdef1234567890

# Имя файла сессии (будет создан как <TG_SESSION_NAME>.session)
TG_SESSION_NAME=news_relay_session

# Каналы-источники через запятую: @username или https://t.me/username
TG_CHANNELS=@durov,@telegram,https://t.me/breakingmash

# ── ВКонтакте ─────────────────────────────────────────────────────────────────
# Токен сообщества ВК (Управление → Настройки → Работа с API → Ключи доступа)
VK_TOKEN=vk1.a.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# peer_id беседы: для групповых бесед = 2000000000 + номер беседы
# Номер беседы виден в URL: vk.com/im?sel=c42 → chat_id=42 → peer_id=2000000042
VK_PEER_ID=2000000042

# ── Фильтрация ────────────────────────────────────────────────────────────────
# Ключевые слова через запятую (без учёта регистра).
# Если пусто — пересылать все сообщения.
KEYWORDS=новость,срочно,важно

# ── Логирование ───────────────────────────────────────────────────────────────
LOG_FILE=news_relay.log
LOG_LEVEL=INFO

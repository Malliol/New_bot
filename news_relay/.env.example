# ── Telegram (MTProto user-сессия) ────────────────────────────────────────────
TG_API_ID=123456
TG_API_HASH=abcdef1234567890abcdef1234567890
TG_SESSION_NAME=news_relay_session

# ── Администратор ─────────────────────────────────────────────────────────────
# Ваш Telegram user ID. Узнать: @getmyid_bot
ADMIN_TG_ID=123456789

# ── Telegram Bot (кнопка /admin → Mini App) ───────────────────────────────────
# Создать через @BotFather → /newbot
BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# URL Cloudflare Worker (появится после wrangler deploy)
# Вид: https://news-relay-admin.<subdomain>.workers.dev
WEBAPP_URL=https://news-relay-admin.YOUR_SUBDOMAIN.workers.dev

# ── ВКонтакте ─────────────────────────────────────────────────────────────────
VK_TOKEN=vk1.a.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
VK_PEER_ID=2000000042

# ── Cloudflare KV (синхронизация настроек на VPS) ────────────────────────────
# Account ID: dash.cloudflare.com → правый столбец → Account ID
CF_ACCOUNT_ID=abcdef1234567890abcdef1234567890

# Namespace ID: Workers & Pages → KV → название неймспейса → ID
CF_KV_NAMESPACE_ID=abcdef1234567890abcdef1234567890

# API Token: dash.cloudflare.com → профиль → API Tokens
# Разрешения: Workers KV Storage → Edit (для нужного аккаунта)
CF_API_TOKEN=your_cloudflare_api_token

# ── Логирование ───────────────────────────────────────────────────────────────
LOG_FILE=news_relay.log
LOG_LEVEL=INFO

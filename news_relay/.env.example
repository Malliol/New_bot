# ── Telegram (MTProto user-сессия) ────────────────────────────────────────────
# Получить на https://my.telegram.org/apps
TG_API_ID=123456
TG_API_HASH=abcdef1234567890abcdef1234567890

# Имя файла сессии (создастся как <имя>.session при первом запуске)
TG_SESSION_NAME=news_relay_session

# ── Администратор ─────────────────────────────────────────────────────────────
# Ваш Telegram user ID (не @username!).
# Узнать: написать @getmyid_bot в Telegram.
ADMIN_TG_ID=123456789

# ── Telegram Bot (для кнопки Mini App) ───────────────────────────────────────
# Создать бота через @BotFather → /newbot → скопировать токен
BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Публичный HTTPS-адрес, где будет доступна Mini App.
# На VPS: настройте nginx + certbot и укажите свой домен.
# Для теста локально можно использовать ngrok: https://ngrok.com
WEBAPP_URL=https://yourdomain.com

# Порт FastAPI-сервера (nginx проксирует на него)
WEBAPP_PORT=8080

# ── ВКонтакте ─────────────────────────────────────────────────────────────────
# Токен сообщества ВК (Управление → Настройки → Работа с API → Ключи доступа)
VK_TOKEN=vk1.a.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# peer_id беседы: 2000000000 + номер беседы
# vk.com/im?sel=c42 → chat_id=42 → peer_id=2000000042
VK_PEER_ID=2000000042

# ── Логирование ───────────────────────────────────────────────────────────────
LOG_FILE=news_relay.log
LOG_LEVEL=INFO

# ── Каналы и ключевые слова ───────────────────────────────────────────────────
# Управляются через Mini App (кнопка /admin в боте) и хранятся в config.json.
